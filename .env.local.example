# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
# Set this after registering webhook with --secret-token flag
TELEGRAM_WEBHOOK_SECRET=

# Google Gemini
GEMINI_API_KEY=

# Portkey AI Gateway (retry/observability/load-balancing for Gemini calls in Telegram bot)
# Sign up at https://app.portkey.ai — free tier is enough for low-volume bot usage.
# Both the load-balancing strategy and retry policy live in the Portkey Config (pc-…),
# so they can be tuned from the dashboard without redeploying.
PORTKEY_API_KEY=
PORTKEY_CONFIG_ID=

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
ALLOWED_EMAIL_DOMAIN=your-company.com

# Google OAuth (Gmail reports)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Teams Bot (optional)
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_TENANT_ID=

# Azure OAuth App — server-side Microsoft token refresh
# Used by getValidProviderToken() for /meet calendar creation and web sendMail
# Can be the same values as TEAMS_BOT_APP_ID/SECRET if using the same Azure app
AZURE_OAUTH_CLIENT_ID=
AZURE_OAUTH_CLIENT_SECRET=

# SendGrid（電子報與交易郵件寄送）
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=
# SendGrid Event Webhook 簽章驗證
SENDGRID_WEBHOOK_SECRET=
# Inbound Parse webhook 驗證
INBOUND_PARSE_SECRET=

# 排程與管理端點驗證
# Vercel cron 呼叫 /api/cron/* 的 Bearer secret
CRON_SECRET=
# 管理維運端點（/api/admin/*）的 secret
ADMIN_SECRET=

# 站台 URL 與 session secret（非 NextAuth 套件，僅沿用命名）
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# 組織 / 電子報資訊（未設定時部分功能以 org settings 或預設值代替）
ORG_NAME=
ORG_EMAIL_DOMAIN=
ORG_OWNER_EMAIL=
ORG_POSTAL_ADDRESS=
COMPANY_WEBSITE=
COMPANY_LINKEDIN=
COMPANY_FACEBOOK=
NEWSLETTER_REPLY_TO=
NEWSLETTER_LOGO_URL=
INTERNAL_EMAIL_DOMAIN=
BCC_INBOX_DOMAIN=

# 功能開關 / 選配
HUNTER_ENABLED=
AI_ASSISTANT_ENABLED=
FEEDBACK_RECIPIENT=
MCP_AGENT_TOKEN=
RELEASE_NOTIFY_TOKEN=

# AI 系統預設模型覆寫（未設定時見 src/lib/aiRouting.ts 的 getDefault）
AI_REVIEW_MODEL=
NEWSLETTER_MODEL_REFINE=
NEWSLETTER_MODEL_TRANSLATE=

# Docs link（選填；未設定時站內 /docs 手冊頁即為預設。GitBook 整合已於 v7.9.9 移除）
NEXT_PUBLIC_DOCS_URL=

# 版本資訊
NEXT_PUBLIC_APP_VERSION=1.0.0
# NEXT_PUBLIC_DEPLOY_TIME 由 Vercel Build Command 自動注入，不需手動設定
