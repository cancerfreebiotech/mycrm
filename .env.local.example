# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
# Set this after registering webhook with --secret-token flag
TELEGRAM_WEBHOOK_SECRET=

# Google Gemini
GEMINI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
ALLOWED_EMAIL_DOMAIN=your-company.com

# Google OAuth (Gmail reports)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Teams Bot (optional)
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_TENANT_ID=

# Docs link (set to GitBook URL after setup)
NEXT_PUBLIC_DOCS_URL=

# 版本資訊
NEXT_PUBLIC_APP_VERSION=1.0.0
# NEXT_PUBLIC_DEPLOY_TIME 由 Vercel Build Command 自動注入，不需手動設定
