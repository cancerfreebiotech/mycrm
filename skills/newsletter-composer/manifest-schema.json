{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "myCRM Newsletter Composer Manifest",
  "description": "Output of the newsletter-composer skill, consumed by myCRM POST /api/newsletter/import",
  "type": "object",
  "required": ["period", "intro", "stories"],
  "additionalProperties": false,
  "properties": {
    "period": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$",
      "description": "Year-month, e.g. 2026-05"
    },
    "intro": {
      "$ref": "#/definitions/trilingualHtml",
      "description": "Opening paragraph, 3 langs, HTML with allowed tags only"
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/story" }
    },
    "promo": {
      "$ref": "#/definitions/trilingualPlain",
      "description": "Optional short plain-text promo (for LINE / Slack / chat). 80-150 chars. Imported into newsletter_campaigns.promo_text per language so the user can copy/paste from quick-send."
    }
  },
  "definitions": {
    "trilingualHtml": {
      "type": "object",
      "required": ["zh-TW", "en", "ja"],
      "additionalProperties": false,
      "properties": {
        "zh-TW": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 },
        "ja": { "type": "string", "minLength": 1 }
      }
    },
    "trilingualText": {
      "type": "object",
      "required": ["zh-TW", "en", "ja"],
      "additionalProperties": false,
      "properties": {
        "zh-TW": { "type": "string", "minLength": 1, "maxLength": 80 },
        "en": { "type": "string", "minLength": 1, "maxLength": 120 },
        "ja": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "trilingualPlain": {
      "type": "object",
      "required": ["zh-TW", "en", "ja"],
      "additionalProperties": false,
      "properties": {
        "zh-TW": { "type": "string", "minLength": 1, "maxLength": 300 },
        "en": { "type": "string", "minLength": 1, "maxLength": 400 },
        "ja": { "type": "string", "minLength": 1, "maxLength": 300 }
      }
    },
    "story": {
      "type": "object",
      "required": ["section", "title", "content_html", "image_files"],
      "additionalProperties": false,
      "properties": {
        "section": {
          "type": "string",
          "enum": ["last_month", "next_month"]
        },
        "title": { "$ref": "#/definitions/trilingualText" },
        "content_html": { "$ref": "#/definitions/trilingualHtml" },
        "image_files": {
          "type": "array",
          "minItems": 0,
          "maxItems": 2,
          "items": {
            "type": "string",
            "pattern": "^images/[a-z0-9][a-z0-9-_]{0,99}\\.(jpg|jpeg|png|webp)$"
          },
          "description": "Filenames inside the zip's images/ folder, prefixed with 'images/'. Sequence-prefixed slugs. Some stories (e.g. link-only podcast/news mentions) may have 0 images."
        },
        "links": {
          "type": "array",
          "items": { "$ref": "#/definitions/link" }
        }
      }
    },
    "link": {
      "type": "object",
      "required": ["url", "label"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        },
        "label": { "$ref": "#/definitions/trilingualText" }
      }
    }
  }
}
